{
  "name": "wodates-mobile-app",
  "version": "0.1.0",
  "description": "WODATES Mobile App - Clean Architecture React Native",
  "main": "expo-router/entry",
  "scripts": {
    "start": "powershell -Command \"$env:EXPO_DEVTOOLS_LISTEN_ADDRESS='0.0.0.0'; $env:REACT_NATIVE_PACKAGER_HOSTNAME='0.0.0.0'; npx expo start --host lan -c\"",
    "start:web": "expo start --web -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "powershell -Command \"$env:EXPO_DEVTOOLS_LISTEN_ADDRESS='0.0.0.0'; $env:REACT_NATIVE_PACKAGER_HOSTNAME='0.0.0.0'; npx expo start --web --host lan -c\"",
    "web:network": "powershell -Command \"$env:EXPO_DEVTOOLS_LISTEN_ADDRESS='0.0.0.0'; $env:REACT_NATIVE_PACKAGER_HOSTNAME='0.0.0.0'; npx expo start --web --host lan -c\"",
    "build": "expo export && node scripts/postexport-copy-cloudflare-files.js",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.js",
    "generate:pwa-screenshots": "node scripts/generate-pwa-screenshots.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@ptomasroos/react-native-multi-slider": "^2.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@supabase/supabase-js": "^2.75.0",
    "axios": "^1.6.7",
    "expo": "^54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.9",
    "expo-document-picker": "~13.0.2",
    "expo-font": "~14.0.9",
    "expo-image-manipulator": "~14.0.7",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-modules-autolinking": "~3.0.8",
    "expo-modules-core": "~3.0.21",
    "expo-router": "^6.0.12",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.8",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react-native": "^0.556.0",
    "metro": "^0.83.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.23.8",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "cypress": "^15.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "~29.7.0",
    "jest-expo": "^54.0.13",
    "metro-react-native-babel-transformer": "^0.77.0",
    "prettier": "^3.2.5",
    "sharp": "^0.33.5",
    "ts-jest": "^29.2.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
