# ===========================================
# WODATES PROJECT - GITIGNORE
# ===========================================
# Monorepo: React Native + Expo + Node.js + Fastify
# Clean Architecture + TypeScript + Testing

# ===========================================
# DEPENDENCIES
# ===========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===========================================
# ENVIRONMENT VARIABLES
# ===========================================
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Local copies of secrets (e.g. backups); never commit
env_/

# ===========================================
# BUILD OUTPUTS
# ===========================================
# TypeScript compilation
dist/
build/
*.tsbuildinfo

# Expo/React Native
.expo/
.expo-shared/
web-build/

# Next.js (if used)
.next/

# ===========================================
