# =============================================================================
# WODATES ai-service — environment template
# Copy to .env and fill in real values (never commit .env).
#   cp env.example .env
# Settings are loaded by app/core/settings.py (Pydantic).
# =============================================================================

# --- Service behaviour --------------------------------------------------------
AI_ENABLED=true
LOG_LEVEL=INFO
# Optional test toggle used by helper scripts
SKIP_LLM_TESTS=false

# LLM for chat/text: ollama | gemini | openai
LLM_PROVIDER=ollama

# Embeddings provider: ollama | gemini | openai (defaults to LLM_PROVIDER if empty)
EMBEDDINGS_PROVIDER=

# --- Ollama -------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT=60000
OLLAMA_EMBEDDING_TIMEOUT=30000
OLLAMA_MERGE_TIMEOUT=600000

AI_MODEL_DOC_LOVE=llama3.2:1b
AI_MODEL_PROFILE_CHATS_TO_RESUME=llama3.2:1b
AI_MODEL_PROFILE_MERGE_RESUMES=llama3.2:1b
AI_MODEL_AFFINITY=gemma3:1b
AI_MODEL_AFFINITY_TIMEOUT=60000

# --- Embeddings (dimension must match DB / backend expectations) --------------
EMBEDDING_DIMENSION=1536

# --- Google Gemini ------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_OUTPUT_TOKENS=200
GEMINI_TIMEOUT=60000
# Legacy name found in some local setups/scripts (runtime uses GEMINI_TIMEOUT)
# GEMINI_TIMEOUT_MS=60000
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=60000

# --- Task-specific generation (all providers) ---------------------------------
DOCLOVE_TEMPERATURE=0.2
DOCLOVE_MAX_OUTPUT_TOKENS=120
DOCLOVE_TOP_P=0.9

PROFILE_RESUME_TEMPERATURE=0.1
PROFILE_RESUME_MAX_OUTPUT_TOKENS=600
PROFILE_RESUME_TOP_P=0.8

PROFILE_MERGE_TEMPERATURE=0.1
PROFILE_MERGE_MAX_OUTPUT_TOKENS=500
PROFILE_MERGE_TOP_P=0.8

AFFINITY_TEMPERATURE=0.15
AFFINITY_MAX_OUTPUT_TOKENS=60
AFFINITY_TOP_P=0.7

# --- Compatibility / integration extras ---------------------------------------
# Present in some local .env files; not required by current ai-service runtime.
# Keep only if your tooling/scripts need them.
# AI_CONTEXT_HISTORY_LIMIT=2
# AI_INCLUDE_USER_CONTEXT=false
# AI_INCLUDE_ACTIVE_MATCHES=false
# OLLAMA_SUMMARIZATION_TIMEOUT=600000
# DOC_LOVE_EMAIL=doclove@wodates.com
# DATABASE_URL=postgresql://user:pass@host:5432/db
# DIRECT_URL=postgresql://user:pass@host:5432/db

# --- Notes --------------------------------------------------------------------
# CORS allowlist defaults are defined in app/core/settings.py (localhost:3000, 3001).
# Uvicorn port is chosen at launch. This repo uses 8010 in VS Code tasks, e.g.:
#   py -m uvicorn main:app --reload --host 127.0.0.1 --port 8010
# Point backend-api AI_SERVICE_BASE_URL / AI_SERVICE_URL at that URL.
