# =============================================================================
# WODATES backend-api — environment template
# Copy to .env and fill in real values (never commit .env).
#   cp env.example .env
# =============================================================================

# --- Required for startup -----------------------------------------------------
# Supabase (server-side; service role must stay secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Doc Love bot user UUID in auth.users / public.users
DOC_LOVE_ID=00000000-0000-4000-8000-000000000001

# Must be exactly this value (backend calls ai-service over HTTP only)
AI_PROVIDER=ai-service

# --- AI microservice ----------------------------------------------------------
# Base URL of ai-service (no trailing path). Match the port you run uvicorn on.
# Default in code if unset: http://127.0.0.1:8010 (see repo README / VS Code task "AI Service")
AI_SERVICE_BASE_URL=http://127.0.0.1:8010
# Alternative name also supported:
# AI_SERVICE_URL=http://127.0.0.1:8010

AI_SERVICE_TIMEOUT=60000
AI_SERVICE_PROFILE_TIMEOUT=660000

# Global AI kill-switch (set to false to disable AI routes/jobs)
AI_ENABLED=true

# Doc Love context (optional tuning)
AI_CONTEXT_HISTORY_LIMIT=2
AI_INCLUDE_USER_CONTEXT=false
AI_INCLUDE_ACTIVE_MATCHES=false

# Affinity one-liner on feed (requires true to call ai-service)
AFFINITY_ENABLED=false

# --- HTTP server --------------------------------------------------------------
NODE_ENV=development
PORT=3000
FASTIFY_LOG_LEVEL=warn

# --- CORS ---------------------------------------------------------------------
# Comma-separated origins (e.g. Expo web, production web). Leave unset for dev defaults in code.
# CORS_ORIGIN=http://localhost:8081,https://your-app.example.com

# --- Rate limiting ------------------------------------------------------------
# DISABLE_RATE_LIMIT=true
# RATE_LIMIT_MAX=100
# RATE_LIMIT_TIME_WINDOW=60000

# --- Background jobs ----------------------------------------------------------
JOB_SCHEDULE_ENABLED=true
JOB_SCHEDULE_CRON=0 3 * * *
JOB_SCHEDULE_TIMEZONE=Europe/Madrid

# --- Admin verification panel -------------------------------------------------
# Use ADMIN_VERIFICATION_SECRET or Basic Auth pair (see README).
# ADMIN_VERIFICATION_SECRET=generate-a-long-random-string
# ADMIN_PANEL_SECRET=
# ADMIN_BASIC_USER=admin
# ADMIN_BASIC_PASSWORD=change-me

# --- Optional maintenance scripts ----------------------------------------------
# DOC_LOVE_EMAIL=doclove@wodates.com
# update-user-password.ts: set TARGET_EMAIL and NEW_PASSWORD (never commit values)
# TARGET_EMAIL=user@example.com
# NEW_PASSWORD=replace-me-minimum-8-chars
# SKIP_LLM_TESTS=false
# INTERNAL_API_SECRET=change-me
# DRY_RUN=1
# DELETE_DB_ROWS=0
